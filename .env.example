# CloudSpray - AWS Configuration for Fireprox IP Rotation
#
# Copy this file to .env and fill in your AWS credentials:
#   cp .env.example .env
#
# Fireprox routes requests through AWS API Gateway so each spray attempt
# comes from a different IP address, bypassing Microsoft's rate limiting.
#
# Your AWS IAM user needs the AmazonAPIGatewayAdministrator policy, or
# a custom policy with: apigateway:POST, apigateway:GET, apigateway:DELETE
#
# If you leave these blank, CloudSpray runs without proxy rotation
# (all requests come from your IP).

AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Comma-separated AWS regions for gateway deployment.
# More regions = more IP diversity. Default: us-east-1,us-west-2,eu-west-1
AWS_REGIONS=us-east-1,us-west-2,eu-west-1
